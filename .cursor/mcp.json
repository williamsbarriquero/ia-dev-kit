{
  "mcpServers": {
    // Camada 1: Built-in (ferramentas nativas do Cursor como Explorer, Bash e Editor)
    
    // Camada 2: Servidores Locais de Engenharia de Contexto
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-context7"
      ],
      "env": {
        "CONTEXT7_API_KEY": "YOUR_API_KEY"
      }
    },
    "mgrep": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-mgrep"
      ]
    },

    // Camada 3: Integrações do Ecossistema RPE (Configurações do Projeto)
    "mcp-jira": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-jira"
      ],
      "env": {
        "JIRA_API_TOKEN": "YOUR_JIRA_API_TOKEN",
        "JIRA_EMAIL": "your-email@rpe.com.br",
        "JIRA_URL": "https://rpe-company.atlassian.net"
      }
    },
    "mcp-github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN"
      }
    },
    "mcp-postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres"
      ],
      "env": {
        "DATABASE_URL": "postgresql://user:password@localhost:5432/rpe_db"
      }
    }
  }
}
